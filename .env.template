## Logging
LOGGING_LEVEL=INFO


## API
APP_NAME="Agentic RAG"
APP_VERSION=0.1.0
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000
APP_PORT=8000


## Auth Provider
## Supported values for now: local, keycloak, oidc, auth0
AUTH_PROVIDER=local


## Local Auth
## Local auth is only for development and tests. Do not use it in production.
LOCAL_AUTH_TOKEN=local-dev-token
LOCAL_USER_ID=local-user
LOCAL_TENANT_ID=local-tenant
LOCAL_WORKSPACE_ID=
LOCAL_ROLES=admin,user
LOCAL_GROUPS=
LOCAL_SCOPES=documents:read,documents:write,documents:delete,query:run,ingestion:write
LOCAL_ACL_VERSION=1


## OIDC / Keycloak / Auth0
## Required when AUTH_PROVIDER is keycloak, oidc, or auth0.
OIDC_ISSUER_URL=
OIDC_AUDIENCE=
OIDC_JWKS_URL=


## PostgreSQL
POSTGRES_DB=agentic_rag
POSTGRES_USER=agentic_rag
POSTGRES_PASSWORD=agentic_rag
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
PGDATA=/var/lib/postgresql/data/pgdata


## Database URLs
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
ALEMBIC_DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
TEST_DATABASE_URL=sqlite+aiosqlite:///./test_agentic_rag.db
DOCKER_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}


## SQLAlchemy
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20


## Redis
REDIS_URL=redis://localhost:6379/0


## Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PARTITIONS=3


## Kafka Topics
KAFKA_INGESTION_PARSE_TOPIC=ingestion.parse
KAFKA_INGESTION_METADATA_TOPIC=ingestion.metadata
KAFKA_INGESTION_CHUNK_TOPIC=ingestion.chunk
KAFKA_INGESTION_EMBED_TOPIC=ingestion.embed
KAFKA_INGESTION_INDEX_TOPIC=ingestion.index
KAFKA_RAG_LONG_QUERY_TOPIC=rag.long_query
KAFKA_EVAL_BATCH_TOPIC=eval.batch
KAFKA_DLQ_INGESTION_TOPIC=dlq.ingestion
KAFKA_DLQ_EMBEDDING_TOPIC=dlq.embedding
KAFKA_DLQ_INDEXING_TOPIC=dlq.indexing
KAFKA_DLQ_RAG_TOPIC=dlq.rag


## Object Storage
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT_URL=http://localhost:9000
DOCKER_S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=agentic_rag
S3_SECRET_ACCESS_KEY=agentic_rag_password
S3_BUCKET_NAME=agentic-rag
S3_REGION=us-east-1
DOCUMENT_UPLOAD_MAX_BYTES=26214400


## Ingestion Worker
INGESTION_WORKER_POLL_SECONDS=5
INGESTION_WORKER_LEASE_SECONDS=300
INGESTION_RETRY_BASE_SECONDS=30
INGESTION_RETRY_MAX_SECONDS=900
INGESTION_CHUNK_SIZE=2000
INGESTION_CHUNK_OVERLAP=200


## OpenSearch
OPENSEARCH_PORT=9200
OPENSEARCH_URL=http://localhost:9200
DOCKER_OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_DISABLE_SECURITY_PLUGIN=true
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_DOCUMENT_INDEX=documents-v1
OPENSEARCH_CHUNK_INDEX=chunks-v1
OPENSEARCH_REQUEST_TIMEOUT_SECONDS=10
OPENSEARCH_INDEX_SHARDS=1
OPENSEARCH_INDEX_REPLICAS=0
INDEXING_WORKER_POLL_SECONDS=5
BM25_INDEX_BATCH_SIZE=100


## Embedding Worker
EMBEDDING_PROVIDER=litellm
EMBEDDING_MODEL_NAME=gemini/gemini-embedding-001
EMBEDDING_DIMENSION=768
EMBEDDING_VECTOR_VERSION=1
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_MAX_INPUT_CHARS=128000
EMBEDDING_BATCH_SIZE=32
EMBEDDING_WORKER_POLL_SECONDS=5
EMBEDDING_WORKER_MAX_CHUNKS_PER_LOOP=100


## LLM Gateway
LLM_SYNTHESIS_ENABLED=false
LLM_PROVIDER=litellm
LLM_API_KEY=
LITELLM_BASE_URL=
DOCKER_LITELLM_BASE_URL=
LITELLM_API_KEY=
DEFAULT_LLM_MODEL=ollama/llama3.1
DEFAULT_SMALL_MODEL=ollama/llama3.1
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=700
LLM_MAX_INPUT_CHARS=64000
LLM_MAX_OUTPUT_TOKENS=8000
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=0.5
LLM_CIRCUIT_BREAKER_ENABLED=true
LLM_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
LLM_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60
LLM_TIMEOUT_SECONDS=30
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=


## Local Model Runtime
OLLAMA_BASE_URL=http://localhost:11434
RERANKER_MODEL_NAME=BAAI/bge-reranker-base


## Agent Runtime Limits
AGENT_MAX_STEPS=8
AGENT_MAX_TOOL_CALLS=12
AGENT_STEP_TIMEOUT_SECONDS=20
AGENT_TOTAL_TIMEOUT_SECONDS=90
AGENT_MAX_SAME_TOOL_REPEAT=2


## Observability
OTEL_SERVICE_NAME=agentic-rag
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_METRICS_PATH=/metrics
